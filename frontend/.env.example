# Optional — defaults to Vite proxy /api → http://localhost:3001
# For phone testing on Wi‑Fi, use the Network URL from `npm run dev` (no change needed if using /api proxy).
# VITE_API_URL=http://192.168.x.x:3001

# Must exceed backend PIPELINE_TIMEOUT_MS (60000)
# VITE_ASK_TIMEOUT_MS=65000

# Must exceed backend NOTES_ROUTE_TIMEOUT_MS (95000)
# VITE_NOTES_TIMEOUT_MS=100000
