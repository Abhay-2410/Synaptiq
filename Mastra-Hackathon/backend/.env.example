PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# LLM (Step 3 — Mastra Tutor agent)
OPENAI_API_KEY=
TUTOR_MODEL=openai/gpt-4.1-mini
TUTOR_USE_LLM=true

# Qdrant (Step 4 — retrieval layer)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=synaptiq_course_material

# Enkrypt AI (Step 5 — verification middleware)
ENKRYPTAI_API_KEY=
ENKRYPTAI_BASE_URL=https://api.enkryptai.com
ENKRYPT_POLICY_NAME=synaptiq-tutor-v1

# Pipeline toggles
USE_ENKRYPT_STUB=true
