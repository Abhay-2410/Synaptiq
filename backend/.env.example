PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── Strict hackathon stack (Mastra + Qdrant + Enkrypt) ──
STRICT_STACK_MODE=true
ALLOW_CORPUS_FALLBACK=false

# Groq LLM (powers Mastra Tutor + Quick Check agents)
GROQ_API_KEY=
TUTOR_MODEL=llama-3.3-70b-versatile
QUICK_CHECK_MODEL=llama-3.1-8b-instant
TUTOR_USE_LLM=true
QUICK_CHECK_USE_LLM=true

TUTOR_LLM_TIMEOUT_MS=25000
QUICK_CHECK_EVAL_TIMEOUT_MS=15000
QUICK_CHECK_ANALYSIS_TIMEOUT_MS=20000
ASK_ROUTE_TIMEOUT_MS=60000

# Qdrant via @mastra/qdrant (required)
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=synaptiq_course_material
QDRANT_VECTOR_ID=synaptiq-qdrant

# Enkrypt AI (required in strict mode — set USE_ENKRYPT_STUB=true only for offline dev)
ENKRYPTAI_API_KEY=
ENKRYPTAI_BASE_URL=https://api.enkryptai.com
ENKRYPT_POLICY_NAME=synaptiq-tutor-v1
USE_ENKRYPT_STUB=false

# Timeouts
QDRANT_TIMEOUT_MS=8000
ENKRYPT_TIMEOUT_MS=35000
ENKRYPT_PER_CALL_TIMEOUT_MS=8000
PIPELINE_TIMEOUT_MS=60000
QDRANT_EMBED_TIMEOUT_MS=3000
GROQ_STARTUP_TIMEOUT_MS=5000
ENKRYPT_PROBE_TIMEOUT_MS=5000
QUICK_CHECK_ROUTE_TIMEOUT_MS=35000

# Notes Simplifier (OCR → Tutor → PDF)
NOTES_MAX_UPLOAD_BYTES=10485760
NOTES_ROUTE_TIMEOUT_MS=95000
NOTES_PIPELINE_TIMEOUT_MS=90000
NOTES_OCR_TIMEOUT_MS=45000
NOTES_SIMPLIFY_TIMEOUT_MS=30000
NOTES_PDF_TIMEOUT_MS=15000
NOTES_MIN_PDF_TEXT_CHARS=80

# Dev — listen on all interfaces for phone testing on same Wi‑Fi
HOST=0.0.0.0
# Comma-separated origins; LAN origins auto-allowed in development
CORS_ORIGIN=http://localhost:5173

# Optional — protect POST /internal/verify in production (header: x-internal-secret)
# INTERNAL_API_SECRET=
