{
  "name": "synaptiq-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed:qdrant": "tsx scripts/seed-qdrant.ts",
    "test:quick-check": "tsx scripts/test-quick-check.ts",
    "test:coverage": "tsx scripts/test-coverage-matrix.ts",
    "test:stem": "tsx scripts/test-stem-solve.ts",
    "test:reasoning": "tsx scripts/test-reasoning-eval.ts",
    "test:answers": "tsx scripts/test-answer-quality.ts",
    "test:groq": "tsx scripts/test-groq-integration.ts",
    "test:stack": "tsx scripts/test-stack-integration.ts",
    "test:qdrant": "tsx scripts/test-qdrant-live.ts",
    "test:sponsor": "tsx scripts/test-sponsor-stack.ts",
    "test:all": "npm run typecheck && npm run test:sponsor && npm run test:answers && npm run test:coverage && npm run test:precision",
    "test:precision": "tsx scripts/test-precision-answers.ts",
    "test:notes": "tsx scripts/test-notes-simplifier.ts",
    "test:notes-subject": "tsx scripts/test-notes-subject.ts",
    "test:demo-ready": "tsx scripts/test-demo-ready.ts",
    "ensure:qdrant-indexes": "tsx scripts/ensure-qdrant-indexes.ts"
  },
  "dependencies": {
    "@mastra/core": "^1.50.0",
    "@mastra/express": "^1.4.5",
    "@mastra/qdrant": "^1.1.1",
    "@napi-rs/canvas": "^1.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "multer": "^2.2.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^6.1.200",
    "tesseract.js": "^7.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.13.10",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
